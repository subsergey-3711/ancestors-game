# ═══════════════════════════════════════════════
# I. ПЕРЕЧИСЛЕННЯ
# ═══════════════════════════════════════════════

class Gender(Enum):
    MALE = "♂ Чоловік"
    FEMALE = "♀ Жінка"

class Season(Enum):
    WET = "Сезон дощів 🌧️"
    DRY = "Сухий сезон ☀️"

class Biome(Enum):
    JUNGLE = "Джунглі 🌴"
    SAVANNA = "Савана 🦒"
    WOODLAND = "Рідколісся 🌳"
    RIVER = "Річка 🏞️"

class Skill(Enum):
    TOOLMAKING = "Виготовлення знарядь"
    HUNTING = "Полювання"
    GATHERING = "Збирання"
    DODGE = "Ухилення"
    CLIMBING = "Лазіння"
    SWIMMING = "Плавання"
    COMMUNICATION = "Комунікація"
    TRACKING = "Слідкування"

class Injury(Enum):
    BROKEN_LEG = "Перелом ноги 🦴"
    BROKEN_ARM = "Перелом руки 🦴"
    INFECTED_WOUND = "Інфікована рана 🩹"
    POISONED = "Отруєння ☠️"
    FEVER = "Лихоманка 🌡️"
    BITE = "Укус хижака 🦷"
    CUT = "Глибока рана 🩸"
    
    @property
    def severity(self):
        return {
            self.BROKEN_LEG: 3, self.BROKEN_ARM: 2,
            self.INFECTED_WOUND: 3, self.POISONED: 4,
            self.FEVER: 2, self.BITE: 1, self.CUT: 2
        }[self]

class Species(Enum):
    PROCONSUL = ("Проконсул 🐒", "Деревна мавпа", -10_000_000)
    ARDIPITHECUS = ("Ардипітек 🦧", "Перше прямоходіння", -7_500_000)
    AUSTRALOPITHECUS = ("Австралопітек 🦍", "Освоєння савани", -5_000_000)
    HOMO_HABILIS = ("Людина вміла 🔨", "Перші кам'яні знаряддя", -3_000_000)
    HOMO_ERECTUS = ("Людина прямоходяча 🔥", "Підкорення вогню", -1_800_000)
    HOMO_HEIDELBERGENSIS = ("Гейдельберзька ⚔️", "Складні знаряддя", -800_000)
    HOMO_SAPIENS = ("Людина розумна 🧠", "Народження культури", -300_000)
    
    def __init__(self, display, milestone, year):
        self.display = display
        self.milestone = milestone
        self.year_bp = year

class GameMode(Enum):
    TUTORIAL = "Новачок 🐣"
    SURVIVAL = "Виживання ☠️"
    CUSTOM = "Користувацький ⚙️"
    ONLINE = "Онлайн 🌐"

# ═══════════════════════════════════════════════
# II. ЕВОЛЮЦІЙНІ РИСИ
# ═══════════════════════════════════════════════

class EvolutionTrait:
    def __init__(self, tid, name, description, category):
        self.id = tid
        self.name = name
        self.description = description
        self.category = category
        self.progress = 0.0
        self.unlocked = False

class EvolutionTree:
    def __init__(self):
        self.traits = {}
        self._init()
    
    def _init(self):
        data = [
            ("grip","Міцний хват 🖐️","Утримувати предмети","motor"),
            ("precision","Точність 🎯","Метання","motor"),
            ("balance","Рівновага 🧘","Ходьба по гілках","motor"),
            ("dexterity","Спритність 🤲","Виготовлення","motor"),
            ("vision","Гострий зір 👁️","Бачити хижаків","sensory"),
            ("hearing","Чуйний слух 👂","Чути небезпеку","sensory"),
            ("smell","Нюх 👃","Відчувати воду","sensory"),
            ("peripheral","Периферія 👀","Широкий огляд","sensory"),
            ("empathy","Емпатія 💕","Розуміння сородичів","social"),
            ("speech","Мова 🗣️","Звукові сигнали","social"),
            ("cooperation","Кооперація 🤝","Спільні дії","social"),
            ("teaching","Навчання 📚","Передача навичок","social"),
            ("memory","Пам'ять 🧠","Запам'ятовувати маршрути","cognitive"),
            ("planning","Планування 📋","Дії наперед","cognitive"),
            ("curiosity","Цікавість 🔍","Потяг до нового","cognitive"),
            ("adaptation","Адаптація 🌍","Звикання","cognitive"),
            ("bipedalism","Прямоходіння 🚶","Економія енергії","physical"),
            ("thumb","Великий палець 🦴","Маніпуляції","physical"),
            ("sweat","Потові залози 💦","Охолодження","physical"),
            ("big_brain","Зріст мозку 🧠","+3 до інтелекту","physical"),
        ]
        for tid, nm, desc, cat in data:
            self.traits[tid] = EvolutionTrait(tid, nm, desc, cat)
    
    def advance(self, category, amount=0.05):
        cand = [t for t in self.traits.values() if not t.unlocked and t.category == category]
        if not cand:
            return None
        ch = random.choice(cand)
        ch.progress = min(1.0, ch.progress + amount)
        if ch.progress >= 1.0 and not ch.unlocked:
            ch.unlocked = True
            return ch.id
        return None
    
    def unlocked_count(self):
        return sum(1 for t in self.traits.values() if t.unlocked)
    
    def total(self):
        return len(self.traits)
    
    def progress(self):
        total = self.total()
        if total == 0: return 0.0
        unlocked = self.unlocked_count()
        partial = sum(t.progress for t in self.traits.values() if not t.unlocked)
        return (unlocked + partial) / total * 100
    
    def summary(self):
        lines = []
        cats = {
            "motor":"Моторика","sensory":"Відчуття",
            "social":"Соціальні","cognitive":"Когнітивні",
            "physical":"Фізичні"
        }
        for cid, cname in cats.items():
            ct = [t for t in self.traits.values() if t.category == cid]
            if not ct: continue
            unl = sum(1 for t in ct if t.unlocked)
            tot = len(ct)
            prog = (unl + sum(t.progress for t in ct if not t.unlocked)) / tot * 100
            fl = int(10 * prog / 100)
            bar = "🧬" * fl + "░" * (10 - fl)
            lines.append(f"  {cname}: [{bar}] {unl}/{tot} ({prog:.0f}%)")
        return "\n".join(lines)

# ═══════════════════════════════════════════════
# III. HOMINID
# ═══════════════════════════════════════════════

class Hominid:
    def __init__(self, name, age=None, gender=None, is_player=False):
        self.name = name
        self.gender = gender if gender else random.choice([Gender.MALE, Gender.FEMALE])
        self.is_player = is_player
        self.age = age if age is not None else random.randint(15, 35)
        self.health = 100
        self.energy = 100
        self.hunger = 0
        self.thirst = 0
        self.fatigue = 0
        self.alive = True
        self.morale = 100
        self.strength = random.randint(3, 7)
        self.speed = random.randint(3, 7)
        self.intelligence = random.randint(3, 7)
        self.skills = {s: 0 for s in Skill}
        self.brain = EvolutionTree()
        self.injuries = []
        self.role = None
        self.experience = 0
        self.children = 0
        self.kills = 0
        self.discoveries = 0
        self.father_name = None
        
        self.pregnant = False
        self.pregnancy_timer = 0
        self.partner_name = None
    
    @property
    def gender_symbol(self):
        return "♂" if self.gender == Gender.MALE else "♀"
    
    @property
    def age_group(self):
        if self.age < 10: return "дитинча"
        if self.age < 16: return "підліток"
        if self.age < 35: return "дорослий"
        if self.age < 50: return "літній"
        return "старейшина"
    
    @property
    def is_adult(self):
        return self.age >= 16
    
    @property
    def is_fertile(self):
        if not self.is_adult: return False
        if self.health < 40: return False
        if self.energy < 30: return False
        if self.pregnant: return False
        return True
    
    @property
    def eff_strength(self):
        penalty = sum(i.severity for i in self.injuries) if self.injuries else 0
        if self.pregnant: penalty += 2
        return max(1, self.strength - penalty)
    
    @property
    def eff_speed(self):
        penalty = sum(i.severity for i in self.injuries) // 2 if self.injuries else 0
        if self.pregnant: penalty += 3
        return max(1, self.speed - penalty)
    
    def stats(self):
        lines = [f"{self.gender_symbol} {self.name} ({self.age_group}), {self.age} років"]
        lines.append(f"   ❤️ {self.health}/100 | ⚡ {self.energy}/100 | 😫 {self.fatigue}/100")
        lines.append(f"   🍖{self.hunger}/100 💧{self.thirst}/100 🏅{self.morale}/100")
        lines.append(f"   💪{self.eff_strength} 🏃{self.eff_speed} 🧠{self.intelligence}")
        if self.pregnant:
            lines.append(f"   🤰 Вагітна! Залишилось: {self.pregnancy_timer} ходів")
        if self.injuries:
            inj_str = ", ".join(f"{i.value}" for i in self.injuries)
            lines.append(f"   🩺 Травми: {inj_str}")
        if self.role:
            lines.append(f"   🏅 Роль: {self.role}")
        if self.brain.unlocked_count() > 0:
            lines.append(f"   🧬 Нейрони: {self.brain.unlocked_count()}/{self.brain.total()}")
        return "\n".join(lines)
    
    def age_one_year(self):
        self.age += 1
        if self.age > 60:
            self.health -= random.randint(5, 15)
        if self.age > 70:
            self.health -= random.randint(10, 25)
        if self.health <= 0:
            self.alive = False
    
    def apply_penalties(self):
        if self.hunger > 80:
            self.health -= 2
            self.energy -= 3
        elif self.hunger > 50:
            self.energy -= 1
        if self.thirst > 80:
            self.health -= 3
            self.energy -= 4
        elif self.thirst > 50:
            self.energy -= 2
        if self.energy <= 0:
            self.health -= 5
        if self.pregnant:
            self.energy -= 2
            self.hunger += 3
            self.thirst += 2
        if self.health <= 0:
            self.alive = False
    
    def rest(self):
        self.energy = min(100, self.energy + random.randint(15, 35))
        self.hunger += random.randint(2, 6)
        self.thirst += random.randint(2, 5)
        self.fatigue = max(0, self.fatigue - random.randint(10, 25))
        result = None
        if self.injuries:
            light = [i for i in self.injuries if i.severity <= 2]
            if light and random.random() < 0.2:
                healed = random.choice(light)
                self.injuries.remove(healed)
                self.health = min(100, self.health + 10)
                result = f"🩹 {healed.value} зажила"
        return result
    
    def eat(self, amt=30):
        self.hunger = max(0, self.hunger - amt)
        self.energy = min(100, self.energy + amt // 3)
    
    def drink(self):
        self.thirst = max(0, self.thirst - 40)
    
    def take_damage(self, dmg, src=""):
        self.health -= dmg
        if self.pregnant and random.random() < 0.3:
            self.pregnant = False
            self.pregnancy_timer = 0
            self.morale = max(0, self.morale - 30)
            print(f"   💔 {self.name} втратила дитину через травму!")
        if self.health <= 0:
            self.alive = False
            return f"💀 {self.name} загинув від {src}!"
        return f"⚡ {self.name} отримав {dmg} урону від {src} (❤️{self.health})"
    
    def gain_exp(self, amt):
        self.experience += amt
        if self.experience >= 100 * (self.intelligence + 1):
            self.intelligence += 1
            self.experience = 0
            self.morale = min(100, self.morale + 10)
            return True
        return False

# ═══════════════════════════════════════════════
# IV. СВІТ
# ═══════════════════════════════════════════════

class World:
    DESCS = {
        Biome.JUNGLE: ["Густі джунглі","Ліани звисають","Вологий ліс"],
        Biome.SAVANNA: ["Золота трава","Розпечене повітря","Висока трава"],
        Biome.WOODLAND: ["Рідкі дерева","Прохолодний переліс","Гілки навісом"],
        Biome.RIVER: ["Широка річка","Дзюрчання води","Риба плескається"],
    }
    HARVEST = {
        Biome.JUNGLE: ("фрукти", 15, 30),
        Biome.SAVANNA: ("коріння", 5, 20),
        Biome.WOODLAND: ("гриби/ягоди", 8, 25),
        Biome.RIVER: ("риба", 15, 35)
    }
    TRANSITIONS = {
        Biome.JUNGLE: [Biome.WOODLAND, Biome.RIVER],
        Biome.SAVANNA: [Biome.WOODLAND, Biome.RIVER],
        Biome.WOODLAND: [Biome.JUNGLE, Biome.SAVANNA, Biome.RIVER],
        Biome.RIVER: [Biome.JUNGLE, Biome.SAVANNA, Biome.WOODLAND],
    }
    
    def __init__(self):
        self.biome = Biome.JUNGLE
        self.weather = "ясно"
        self.time = "ранок"
        self.day = 1
        self.season = Season.WET
        self.season_days = 0
        self.survival_timer = 0
        self.drought_timer = 0
    
    def describe(self):
        desc = random.choice(self.DESCS[self.biome])
        w = ""
        t = f" Зараз {self.time}."
        if self.weather == "дощ": w = " Мрячить дощ."
        elif self.weather == "буря": w = " Буря!"
        elif self.weather == "спека": w = " Спека."
        return f"📍 {self.biome.value} | День {self.day} | {self.weather}{t}{w}\n🌍 {self.season.value}\n{desc}"
    
    def advance(self):
        times = ["ранок","день","вечір","ніч"]
        idx = times.index(self.time)
        if idx < 3:
            self.time = times[idx + 1]
        else:
            self.time = "ранок"
            self.day += 1
            self.weather = random.choice(["ясно","ясно","дощ","спека","буря"])
        self.season_days += 0.5
        if self.season_days >= 5:
            self.season_days = 0
            self.season = Season.WET if self.season == Season.DRY else Season.DRY
            self.weather = "дощ" if self.season == Season.WET else "спека"
            self.drought_timer = 0 if self.season == Season.WET else 5
    
    def forage_mod(self):
        return 1.5 if self.season == Season.WET else 0.7
    
    def move_to(self, b):
        if b in self.TRANSITIONS.get(self.biome, []):
            self.biome = b
            self.advance()
            return True
        return False

# ═══════════════════════════════════════════════
# V. ЕВОЛЮЦІЯ
# ═══════════════════════════════════════════════

class EvolutionEngine:
    def __init__(self, clan):
        self.clan = clan
        self.tree = EvolutionTree()
        self.species = Species.PROCONSUL
        self.points = 0
        self.history = []
        self.reqs = {
            Species.PROCONSUL: (0, 2, 0, 0, [], 0),
            Species.ARDIPITHECUS: (3, 3, 1, 0, ["bipedalism"], 0),
            Species.AUSTRALOPITHECUS: (6, 4, 3, 0, ["bipedalism","sweat"], 3),
            Species.HOMO_HABILIS: (9, 4, 5, 2, ["thumb","dexterity"], 5),
            Species.HOMO_ERECTUS: (12, 5, 7, 3, ["speech","planning"], 8),
            Species.HOMO_HEIDELBERGENSIS: (15, 6, 10, 4, ["cooperation","big_brain"], 12),
            Species.HOMO_SAPIENS: (18, 8, 14, 5, ["memory","teaching","empathy"], 16),
        }
    
    def check(self):
        sp = list(Species)
        idx = sp.index(self.species)
        if idx >= len(sp) - 1:
            return False, None, ["Максимум"]
        nxt = sp[idx + 1]
        data = self.reqs.get(nxt)
        if not data: return False, None, ["Нема вимог"]
        mn_tr, mn_cl, mn_gen, mn_tl, req_tr, req_disc = data
        fail = []
        if self.tree.unlocked_count() < mn_tr:
            fail.append(f"Риси: {self.tree.unlocked_count()}/{mn_tr}")
        alive = len([m for m in self.clan.members if m.alive])
        if alive < mn_cl:
            fail.append(f"Клан: {alive}/{mn_cl}")
        if self.clan.generation < mn_gen:
            fail.append(f"Покоління: {self.clan.generation}/{mn_gen}")
        if self.clan.tool_level < mn_tl:
            fail.append(f"Знаряддя: {self.clan.tool_level}/{mn_tl}")
        for tid in req_tr:
            t = self.tree.traits.get(tid)
            if t and not t.unlocked:
                fail.append(f"Риса: {t.name}")
        if len(self.clan.discoveries) < req_disc:
            fail.append(f"Відкриття: {len(self.clan.discoveries)}/{req_disc}")
        ready = len(fail) == 0
        return ready, nxt if ready else None, fail
    
    def leap(self):
        ready, nxt, fail = self.check()
        if not ready or not nxt:
            return "НЕМОЖЛИВО", fail
        old = self.species
        self.species = nxt
        for m in self.clan.members:
            if m.alive:
                m.health = min(100, m.health + 30)
                m.energy = min(100, m.energy + 30)
                m.morale = min(100, m.morale + 50)
                m.injuries = []
                sb = random.choice(list(Skill))
                m.skills[sb] = min(10, m.skills[sb] + 2)
        phys = [t for t in self.tree.traits.values() if t.category == "physical" and not t.unlocked]
        if phys:
            for t in random.sample(phys, min(2, len(phys))):
                t.unlocked = True; t.progress = 1.0
        if self.clan.tool_level < 5:
            self.clan.tool_level = min(5, self.clan.tool_level + 1)
        self.clan.current_year = nxt.year_bp
        entry = f"⚡⚡⚡ {old.display} → {nxt.display} ⚡⚡⚡\n  🏆 {nxt.milestone}\n  📅 {abs(nxt.year_bp)} років до н.е."
        self.history.append(entry)
        self.clan.add_chronicle(f"⚡ ЕВОЛЮЦІЯ: {nxt.display}")
        self.clan.generation += 1
        self.points = 0
        return entry, []
    
    def summary(self):
        lines = ["📜 ІСТОРІЯ ЕВОЛЮЦІЇ", "=" * 50]
        if not self.history: lines.append("  Еволюція не почата")
        else:
            for i, e in enumerate(self.history, 1): lines.append(f"  {i}. {e}")
        lines.append("=" * 50)
        lines.append(f"🔬 {self.species.display} | {self.species.milestone}")
        return "\n".join(lines)

# ═══════════════════════════════════════════════
# VI. КЛАН
# ═══════════════════════════════════════════════

class Clan:
    def __init__(self):
        self.members = []
        self.name = "Клан предків"
        self.generation = 0
        self.total_members = 0
        self.total_deaths = 0
        self.tool_level = 0
        self.food_storage = 50
        self.water_storage = 50
        self.herbs_storage = 3
        self.discoveries = []
        self.chronicle = []
        self.current_year = -10_000_000
        self.materials = {}
        self.crafted_items = {}
        self.MALE_NAMES = ["Адам","Бо","Дар","Зук","Нок","Рук","Тум","Сол","Гор","Фі","Кай","Рон","Бек","Тор"]
        self.FEMALE_NAMES = ["Айла","Кіра","Міра","Вії","Ло","Зара","Ніна","Тара","Сара","Ліа","Ріа","Дора"]
    
    @property
    def player(self):
        for m in self.members:
            if m.is_player and m.alive: return m
        return None
    
    @property
    def alive_members(self):
        return [m for m in self.members if m.alive]
    
    @property
    def injured_members(self):
        return [m for m in self.members if m.alive and m.injuries]
    
    @property
    def fertile_members(self):
        return [m for m in self.members if m.alive and m.is_fertile]
    
    @property
    def pregnant_members(self):
        return [m for m in self.members if m.alive and m.pregnant]
    
    @property
    def male_members(self):
        return [m for m in self.members if m.alive and m.gender == Gender.MALE]
    
    @property
    def female_members(self):
        return [m for m in self.members if m.alive and m.gender == Gender.FEMALE]
    
    def add_member(self, name, gender=None, age=None, is_player=False):
        h = Hominid(name, age=age, gender=gender, is_player=is_player)
        self.members.append(h)
        self.total_members += 1
        return h
    
    def add_chronicle(self, ev):
        yr = f"Рік {abs(self.current_year // 1_000_000)} млн років до н.е."
        self.chronicle.append(f"[{yr}] {ev}")

# ═══════════════════════════════════════════════
# VII. ГРА
# ═══════════════════════════════════════════════

class NetworkChatServer:
    def __init__(self, host="127.0.0.1", port=5000, server_name="Ancestors"):
        self.host = host
        self.port = port
        self.server_name = server_name
        self.discovery_port = 5001
        self.running = True
        self.socket = None
        self.discovery_socket = None
        self.thread = None
        self.discovery_thread = None
        self.clients = []
        self.lock = threading.Lock()
        self.messages = []

    def start(self):
        self.socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        self.socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.socket.bind((self.host, self.port))
        self.socket.listen(5)
        self.thread = threading.Thread(target=self._accept_loop, daemon=True)
        self.thread.start()
        self.discovery_socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        self.discovery_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        self.discovery_socket.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
        self.discovery_socket.bind(("0.0.0.0", self.discovery_port))
        self.discovery_thread = threading.Thread(target=self._discovery_loop, daemon=True)
        self.discovery_thread.start()
        return True

    def stop(self):
        self.running = False
        try:
            self.socket.close()
        except Exception:
            pass
        try:
            self.discovery_socket.close()
        except Exception:
            pass

    def _discovery_loop(self):
        while self.running:
            try:
                data, addr = self.discovery_socket.recvfrom(1024)
                if not data:
                    continue
                text = data.decode("utf-8", "ignore")
                if text.strip() == "ANCESTORS_DISCOVER":
                    payload = {
                        "type": "server_info",
                        "host": self.host,
                        "port": self.port,
                        "clan_name": self.server_name,
                    }
                    self.discovery_socket.sendto(json.dumps(payload).encode("utf-8"), addr)
            except OSError:
                break
            except Exception:
                continue

    def _accept_loop(self):
        while self.running:
            try:
                conn, addr = self.socket.accept()
            except OSError:
                break
            conn.settimeout(1.0)
            with self.lock:
                self.clients.append(conn)
            threading.Thread(target=self._handle_client, args=(conn, addr), daemon=True).start()

    def _handle_client(self, conn, addr):
        try:
            self._send_payload(conn, {"type": "sync", "messages": self.messages[-20:]})
            while self.running:
                data = conn.recv(4096)
                if not data:
                    break
                text = data.decode("utf-8", "ignore").strip()
                if not text:
                    continue
                for line in text.splitlines():
                    if not line:
                        continue
                    try:
                        payload = json.loads(line)
                    except Exception:
                        continue
                    if payload.get("type") == "join":
                        self.broadcast({"type": "chat", "message": {"author": "Система", "text": f"{payload.get('author', 'Клан')} підключився до чату", "system": True}})
                    elif payload.get("type") == "clan_status":
                        self.broadcast(payload)
                    elif payload.get("type") == "chat":
                        msg = payload.get("message") or payload
                        self.messages.append({
                            "author": msg.get("author", "Система"),
                            "text": msg.get("text", ""),
                            "system": msg.get("system", False),
                        })
                        self.messages = self.messages[-20:]
                        self.broadcast({"type": "chat", "message": self.messages[-1]})
        except Exception:
            pass
        finally:
            with self.lock:
                self.clients = [c for c in self.clients if c is not conn]
            try:
                conn.close()
            except Exception:
                pass

    def broadcast(self, payload):
        data = (json.dumps(payload, ensure_ascii=False) + "\n").encode("utf-8")
        with self.lock:
            dead = []
            for conn in self.clients:
                try:
                    conn.sendall(data)
                except Exception:
                    dead.append(conn)
            for conn in dead:
                try:
                    conn.close()
                except Exception:
                    pass
            self.clients = [c for c in self.clients if c not in dead]

    def _send_payload(self, conn, payload):
        conn.sendall((json.dumps(payload, ensure_ascii=False) + "\n").encode("utf-8"))


